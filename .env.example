# Copy this file to .env and fill real values
# cp .env.example .env

# Required: external MongoDB connection string
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/pos_backend?retryWrites=true&w=majority

# Required in production: use strong random strings
JWT_SECRET=change-me-in-production
NEXTAUTH_SECRET=change-me-in-production
